{
  "name": "psycle-class-finder-ios",
  "version": "1.0.0",
  "description": "Psycle Class Finder — iOS app via Capacitor",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "sync:check": "node build.js --check",
    "sync": "node build.js && npx cap sync ios",
    "open": "npx cap open ios",
    "build:open": "node build.js && npx cap sync ios && npx cap open ios",
    "update-web": "node build.js"
  },
  "dependencies": {
    "@capacitor/browser": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@ebarooni/capacitor-calendar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0"
  }
}
